# GitHub personal access token — needs read access to public repos
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_token_here

# Groq API key — used for LLM narration generation
# Get at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Comma-separated list of allowed frontend origins (no trailing slash)
# Dev default (localhost) is used if this is not set
# In production, set this to your actual frontend URL e.g. https://gitflix.netlify.app
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
